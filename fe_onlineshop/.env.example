# =====================================================================
# ONLINESHOP — Environment variables
# Salin file ini menjadi ".env" (atau ".env.production") lalu isi nilainya.
# JANGAN commit file .env asli ke git.
# =====================================================================

# --- Database (MySQL/MariaDB) ---
# Di lokal (XAMPP) boleh dikosongkan — fallback ke localhost/root/onlineshop.
# Di Hostinger, isi sesuai data dari hPanel > Databases.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=onlineshop
# DB_CONNECTION_LIMIT=10

# --- Auth ---
# WAJIB di production. Generate string acak panjang, mis.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=ganti-dengan-string-acak-panjang

# --- Google OAuth (OPSIONAL — hanya jika ingin login dengan Google) ---
# Redirect URI yang didaftarkan di Google Console:
#   https://NAMADOMAIN-ANDA/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
