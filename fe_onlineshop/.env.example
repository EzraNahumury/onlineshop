# =====================================================================
# ONLINESHOP — Environment variables
# Salin file ini menjadi ".env" (atau ".env.production") lalu isi nilainya.
# JANGAN commit file .env asli ke git.
# =====================================================================

# --- Database (MySQL/MariaDB) ---
# Di lokal (XAMPP) boleh dikosongkan — fallback ke localhost/root/onlineshop.
# Di Hostinger, isi sesuai data dari hPanel > Databases.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=onlineshop
# DB_CONNECTION_LIMIT=10

# --- Auth ---
# WAJIB di production. Generate string acak panjang, mis.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=ganti-dengan-string-acak-panjang

# --- Upload (OPSIONAL tapi DISARANKAN di produksi) ---
# Folder penyimpanan file upload (foto produk/kategori/bukti transfer).
# Set ke folder PERSISTEN DI LUAR folder deploy agar TIDAK hilang saat redeploy.
# Contoh Hostinger: /home/u768480753/onlineshop_uploads
# Kosongkan = default ke public/uploads (hilang jika folder deploy ditimpa).
# UPLOAD_DIR=/home/u768480753/onlineshop_uploads

# --- Timezone DB (OPSIONAL) — default +07:00 (WIB) ---
# DB_TIMEZONE=+07:00

# --- JNE API (akun AYRES sudah "Live" sejak 26 Jun 2026) ---
# Tanpa JNE_ORIGIN_CODE, sistem otomatis fallback ke ongkir flat (lihat
# lib/payment-config.ts) — checkout tidak akan pernah gagal karena ini.
# Default di kode (lib/jne.ts) masih kredensial SANDBOX (boleh dipakai untuk
# testing tanpa setup apa pun). Isi env di bawah dengan kredensial LIVE untuk
# benar-benar dipakai produksi — PERHATIKAN port LIVE BEDA per API
# (10205 untuk Tariff & Tracking, 10206 untuk Pickup/Cashless; sandbox semua
# di 10202).
# JNE_USERNAME=AYRES
# JNE_API_KEY=<api_key dari tab Setting dashboard apidash.jne.co.id>
# JNE_API_BASE_URL=https://apiv2.jne.co.id:10205/tracing/api/pricedev
# JNE_TRACKING_BASE_URL=https://apiv2.jne.co.id:10205/tracing/api/list/v1/cnote
# JNE_PICKUP_BASE_URL=https://apiv2.jne.co.id:10206/pickupcashless
# JNE_ORIGIN_CODE=JOG20100
# ^ Gudang asli toko = JOG20100 (Bantul, Kab. Bantul). Aman dipakai sekarang
#   karena akun sudah Live (data tarif live lengkap untuk semua origin —
#   beda dari sandbox yang cuma lengkap untuk JOG10000/Yogyakarta kota).

# --- JNE API PICKUP/CASHLESS — identitas tambahan (WAJIB sebelum dipakai) ---
# JNE meng-assign cust_id BERBEDA per jenis layanan ke akun corporate Anda
# (BUKAN username/api_key biasa, dan tidak muncul di dashboard — tanya account
# rep JNE). Sistem otomatis memilih cust_id sesuai layanan yang dipilih
# pelanggan saat checkout (JTR -> JNE_CUST_ID_JTR, selain itu -> _REG).
# MERCHANT_ID bebas ditentukan seller sendiri (kata JNE). Tanpa _REG terisi,
# tombol "Buat Resi Otomatis (JNE)" di admin menampilkan error jelas (bukan crash).
# JNE_CUST_ID_REG=         # cust_id untuk layanan REG & YES
# JNE_CUST_ID_JTR=         # cust_id untuk layanan JTR
# JNE_MERCHANT_ID=AYRES    # ID merchant pilihan seller (bebas, stabil)
# JNE_BRANCH_CODE=CGK000
# ^ CGK000 = nilai uji coba resmi dari dokumentasi JNE untuk sandbox. GANTI
#   ke kode branch asli (cabang JNE terdekat gudang) kalau pickup ditolak.

# --- Profil Toko / Gudang (dipakai sebagai data SHIPPER saat buat resi JNE) ---
# PLACEHOLDER — isi dengan alamat gudang & kontak asli sebelum dipakai live.
# SHOP_NAME=AYRES
# SHOP_CONTACT_NAME=Admin AYRES
# SHOP_PHONE=
# SHOP_ADDRESS_1=
# SHOP_ADDRESS_2=
# SHOP_DISTRICT=BANTUL
# SHOP_CITY=BANTUL
# SHOP_ZIP=
# SHOP_REGION=DI YOGYAKARTA

# --- Google OAuth (OPSIONAL — hanya jika ingin login dengan Google) ---
# Redirect URI yang didaftarkan di Google Console:
#   https://NAMADOMAIN-ANDA/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
